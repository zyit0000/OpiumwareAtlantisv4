{
  "$schema": "https://schema.tauri.app/config/2.0.0",
  "productName": "Atlantis",
  "version": "0.1.4",
  "identifier": "com.atlantis.ide",
  
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Atlantis v4",
        "width": 974,
        "height": 617,
        "decorations": false,
        "resizable": true,
        "fullscreen": false,
        "center": true,
        "transparent": true,
        "alwaysOnTop": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "createUpdaterArtifacts": false,
    "windows": {
      "certificateThumbprint": null,
      "digestAlgorithm": "sha256",
      "timestampUrl": ""
    },
    "macOS": {
      "minimumSystemVersion": "10.15"
    }
  },
  
  "plugins": {
    "updater": {
      "active": false
    }
  }
}